{
  "functions": {
    "source": "apps/functions",
    "codebase": "telegram-codex-control",
    "runtime": "nodejs24",
    "predeploy": [
      "npm --prefix \"$PROJECT_DIR\" run build:shared",
      "npm --prefix \"$PROJECT_DIR\" run build:functions"
    ]
  },
  "firestore": {
    "rules": "infra/firestore.rules",
    "indexes": "infra/firestore.indexes.json"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
