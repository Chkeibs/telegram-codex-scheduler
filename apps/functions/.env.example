GCP_PROJECT_ID=replace_with_new_dedicated_project_id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCE_INSTANCE_NAME=telegram-codex-worker
RESULTS_BUCKET=your-new-dedicated-project-codex-results
TELEGRAM_FUNCTION_SERVICE_ACCOUNT=telegram-webhook@your-new-dedicated-project.iam.gserviceaccount.com
WAKE_FUNCTION_SERVICE_ACCOUNT=wake-worker@your-new-dedicated-project.iam.gserviceaccount.com
DELIVERY_FUNCTION_SERVICE_ACCOUNT=result-delivery@your-new-dedicated-project.iam.gserviceaccount.com
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE=codex-wakeups
CLOUD_TASKS_HANDLER_URL=https://us-central1-PROJECT_ID.cloudfunctions.net/taskHandler
CLOUD_TASKS_INVOKER_SERVICE_ACCOUNT=cloud-tasks-invoker@PROJECT_ID.iam.gserviceaccount.com
TELEGRAM_ALLOWED_USER_IDS=123456789
DEFAULT_TIMEZONE=Europe/Paris
DEFAULT_WORKDIR_KEY=default
WORKDIR_KEYS=default,scheduler
BOOT_LEAD_SECONDS=90
CONVERSATION_TTL_MINUTES=30
MAX_TELEGRAM_OUTPUT_CHARS=3500
WAKE_RETRY_DELAY_SECONDS=60

# TELEGRAM_BOT_TOKEN and TELEGRAM_WEBHOOK_SECRET are Secret Manager values.
