{
  "name": "@telegram-codex/functions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --outfile=lib/index.js --external:firebase-admin --external:firebase-admin/* --external:firebase-functions --external:firebase-functions/* --external:@google-cloud/compute --external:@google-cloud/tasks --external:@google-cloud/storage --external:telegraf --external:zod",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:emulators": "vitest run --config vitest.emulator.config.ts"
  },
  "dependencies": {
    "@google-cloud/compute": "^5.0.0",
    "@google-cloud/storage": "^7.21.0",
    "@google-cloud/tasks": "^6.2.1",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.0.1",
    "telegraf": "^4.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
